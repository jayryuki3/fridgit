# Fridgit Environment Configuration

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=fridgit
DB_PASS=your_database_password_here
DB_NAME=fridgit

# Authentication
JWT_SECRET=your_jwt_secret_here

# Security Mode
# Set to false for household/kiosk mode (no passwords, just pick your name)
# Set to true (default) for full email + password authentication
SECURE_ACCESS=true

# Spoonacular API (for recipe suggestions)
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# Server
PORT=3000
